# =============================================================================
# Huntlist — variabili d'ambiente. Copia in `.env.local` e compila con i valori
# del tuo progetto Supabase. NON committare mai `.env.local`.
# =============================================================================

# --- Supabase (Project Settings -> API) ---------------------------------------
# URL del progetto, es. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Chiave pubblicabile (sb_publishable_...). Esposta al browser: e' sicura,
# protetta dalla RLS. In progetti legacy e' la "anon key".
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chiave segreta (sb_secret_...). SOLO server, MAI esposta al client.
# Usata da codice server privilegiato (es. service-role). Lasciala vuota finche'
# non serve davvero (non usata nello scaffold della Fase 1).
SUPABASE_SECRET_KEY=

# --- Resend (email transazionali) ---------------------------------------------
# API key dal tuo account Resend (https://resend.com/api-keys)
RESEND_API_KEY=
# Indirizzo mittente: deve essere su un dominio verificato in Resend.
# Esempio: noreply@tuodominio.com
RESEND_FROM_EMAIL=
# (Opzionale) Destinatario di override per i test locali.
# Se presente, tutte le email vengono inviate a questo indirizzo invece
# che al destinatario reale. Rimuovi in produzione.
RESEND_TEST_EMAIL=

# --- App ----------------------------------------------------------------------
# URL pubblico dell'app, usato nei redirect di auth. In locale:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
